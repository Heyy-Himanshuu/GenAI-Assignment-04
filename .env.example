# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your Gemini API key.
#   cp .env.example .env
# Everything below the key is optional and shown with its default value.
#
# Get a FREE Gemini API key at: https://aistudio.google.com/apikey
# ---------------------------------------------------------------------------

# REQUIRED — your Google Gemini API key (free tier works fine).
GEMINI_API_KEY=AIza...

# --- Model / reasoning -----------------------------------------------------
GEMINI_MODEL=gemini-2.5-flash    # vision-capable Gemini model used as the "brain"
ENABLE_THINKING=true             # use Gemini 2.5 "thinking" for better decisions
MAX_OUTPUT_TOKENS=8192           # output cap per model turn

# --- The task --------------------------------------------------------------
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form
FORM_NAME_VALUE=Jane Doe
FORM_DESCRIPTION_VALUE=This form was filled automatically by a Gemini-powered vision agent using Playwright.

# --- Browser ---------------------------------------------------------------
HEADLESS=false                   # false = show the browser window (great for demos)
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800
NAV_TIMEOUT_MS=45000             # page navigation timeout
ACTION_PAUSE_MS=400              # pause after each action so the page can settle

# --- Agent loop / logging --------------------------------------------------
MAX_STEPS=25                     # safety cap on agent iterations
SCREENSHOTS_DIR=screenshots
LOGS_DIR=logs
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
