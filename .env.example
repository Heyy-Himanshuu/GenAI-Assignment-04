# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your Anthropic API key.
#   cp .env.example .env
# Everything below the key is optional and shown with its default value.
#
# Get an Anthropic API key at: https://console.anthropic.com/settings/keys
# ---------------------------------------------------------------------------

# REQUIRED — your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — fallback keys. The agent automatically rotates to the next one when
# a key is rate-limited (HTTP 429) or rejected (401/403). Use keys from DIFFERENT
# accounts/workspaces so each brings its own separate rate-limit pool.
# ANTHROPIC_API_KEY_2=sk-ant-...
# ANTHROPIC_API_KEY_3=sk-ant-...

# --- Model / reasoning -----------------------------------------------------
ANTHROPIC_MODEL=claude-opus-4-8   # vision-capable Claude model used as the "brain"
ENABLE_THINKING=true              # use Claude adaptive thinking for better decisions
MAX_OUTPUT_TOKENS=16000           # output cap per model turn (non-streaming-safe)

# --- The task --------------------------------------------------------------
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form
FORM_NAME_VALUE=Jane Doe
FORM_DESCRIPTION_VALUE=This form was filled automatically by a Claude-powered vision agent using Playwright.

# --- Browser ---------------------------------------------------------------
HEADLESS=false                   # false = show the browser window (great for demos)
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800
NAV_TIMEOUT_MS=45000             # page navigation timeout
ACTION_PAUSE_MS=400              # pause after each action so the page can settle

# --- Agent loop / logging --------------------------------------------------
MAX_STEPS=25                     # safety cap on agent iterations
SCREENSHOTS_DIR=screenshots
LOGS_DIR=logs
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
